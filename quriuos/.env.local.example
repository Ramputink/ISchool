# ============================================================
# Quriuos — Variables de entorno para ElevenLabs
# ============================================================
# Copia este archivo a .env.local y rellena cada valor con el
# agent-id correspondiente del dashboard de ElevenLabs:
#   https://elevenlabs.io/app/conversational-ai/agents
#
# Cada agente = una experiencia de voz distinta dentro de la app.
# ============================================================

# ── API key (SOLO servidor — sin NEXT_PUBLIC) ───────────────
# La usa /api/elevenlabs-token para generar tokens de conversación
# (los agentes pueden ser privados; la key nunca llega al navegador).
# Con ella también puedes autocrear los agentes:  node scripts/create-agents.mjs
ELEVENLABS_API_KEY=sk_REEMPLAZAR_API_KEY

# ── Agent IDs (cliente, NEXT_PUBLIC) ────────────────────────
# Se rellenan solos al ejecutar scripts/create-agents.mjs,
# o a mano con los agent-id del dashboard.

# ── Bloque 1: Coach personal inspiracional ──────────────────
# Agente que actúa como coach de descubrimiento de intereses.
NEXT_PUBLIC_EL_COACH_AGENT_ID=REEMPLAZAR_COACH_AGENT_ID

# ── Bloque 3: Orientador vocacional ─────────────────────────
# Agente que integra el perfil completo y orienta el futuro profesional.
NEXT_PUBLIC_EL_VOCATIONAL_AGENT_ID=REEMPLAZAR_VOCATIONAL_AGENT_ID

# ── Bloque 2: Personajes / Referentes ───────────────────────
# Un agente por personaje. Crear cada uno en el dashboard de ElevenLabs
# con el clon de voz y el prompt del personaje correspondiente.

# Stephen Hawking (categoría: ciencia)
NEXT_PUBLIC_EL_HAWKING_AGENT_ID=REEMPLAZAR_HAWKING_AGENT_ID

# Steve Jobs (categoría: tecnología)
NEXT_PUBLIC_EL_JOBS_AGENT_ID=REEMPLAZAR_JOBS_AGENT_ID

# Elon Musk (categoría: tecnología)
NEXT_PUBLIC_EL_MUSK_AGENT_ID=REEMPLAZAR_MUSK_AGENT_ID

# Cristiano Ronaldo (categoría: deporte)
NEXT_PUBLIC_EL_CR7_AGENT_ID=REEMPLAZAR_CR7_AGENT_ID

# Lionel Messi (categoría: deporte)
NEXT_PUBLIC_EL_MESSI_AGENT_ID=REEMPLAZAR_MESSI_AGENT_ID

# Taylor Swift (categoría: música)
NEXT_PUBLIC_EL_TAYLOR_AGENT_ID=REEMPLAZAR_TAYLOR_AGENT_ID

# Ibai Llanos (categoría: arte / comunicación digital)
NEXT_PUBLIC_EL_IBAI_AGENT_ID=REEMPLAZAR_IBAI_AGENT_ID
