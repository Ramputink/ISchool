# Config LOCAL de los servicios del RAG (copiar a services/.env). Sin API keys.

# --- Base de datos (Postgres + pgvector local) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iceschool

# --- Embeddings locales vía Ollama ---
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=bge-m3            # multilingüe, 1024 dims (coincide con vector(1024))

# --- OCR de matemáticas ---
MATHOCR_BACKEND=nougat        # open-source local; 'mathpix' solo si se licencia

# --- LLM del tutor para desarrollo (opcional, local) ---
# OLLAMA_CHAT_MODEL=qwen2.5
